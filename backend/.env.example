# Server
PORT=3001
NODE_ENV=development

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=agi_fbhc_homepage

# GitHub (optional - increases rate limit from 60 to 5000 requests/hour)
GITHUB_TOKEN=ghp_your_token_here

# WeChat scraping
WECHAT_SCRAPE_INTERVAL_MINUTES=60

# Cache (seconds, default 5 minutes)
CACHE_TTL_SECONDS=300

# CORS (frontend URL)
CORS_ORIGIN=*
